TYPE=TRIGGERS
triggers='CREATE DEFINER=`root`@`localhost` TRIGGER TRG_Insert_MovieAward\nBEFORE INSERT ON Movie_Award\nFOR EACH ROW\nBEGIN\n    DECLARE v_year INT;\n    SELECT Release_Year INTO v_year\n    FROM Movie\n    WHERE Movie_Id = NEW.Movie_Id;\n\n    IF NEW.Award_Year < v_year THEN\n        SET NEW.Award_Year = v_year;\n    END IF;\nEND' 'CREATE DEFINER=`root`@`localhost` TRIGGER trg_AwardPoints_Insert\nAFTER INSERT ON Movie_Award\nFOR EACH ROW\nBEGIN\n    DECLARE v_points INT DEFAULT 0;\n\n    -- Assign points based on Result\n    IF NEW.Result = \'Won\' THEN\n        SET v_points = 10;\n    ELSEIF NEW.Result = \'Nominated\' THEN\n        SET v_points = 5;\n    ELSE \n        SET v_points = 0;\n    END IF;\n\n    -- If entry already exists → update\n    IF EXISTS (SELECT 1 FROM Award_Points WHERE Movie_Id = NEW.Movie_Id) THEN\n        UPDATE Award_Points\n        SET Total_Points = Total_Points + v_points\n        WHERE Movie_Id = NEW.Movie_Id;\n\n    -- Else → create new entry\n    ELSE\n        INSERT INTO Award_Points (Movie_Id, Total_Points)\n        VALUES (NEW.Movie_Id, v_points);\n    END IF;\nEND' 'CREATE DEFINER=`root`@`localhost` TRIGGER TRG_Insert_AwardPoints\nAFTER INSERT ON Movie_Award\nFOR EACH ROW\nBEGIN\n    DECLARE v_points INT;\n    DECLARE v_current INT;\n\n    SET v_points = fn_CalcAwardPoints(NEW.Result);\n\n    SET v_current = (\n        SELECT Total_Points\n        FROM Award_Points\n        WHERE Movie_Id = NEW.Movie_Id\n    );\n\n    IF v_current IS NULL THEN\n        INSERT INTO Award_Points VALUES (NEW.Movie_Id, v_points);\n    ELSE\n        UPDATE Award_Points\n        SET Total_Points = v_current + v_points\n        WHERE Movie_Id = NEW.Movie_Id;\n    END IF;\nEND'
sql_modes=1098907648 1098907648 1098907648
definers='root@localhost' 'root@localhost' 'root@localhost'
